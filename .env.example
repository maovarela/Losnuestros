# Convex deployment URL (auto-generated when running `npx convex dev` the first time)
NEXT_PUBLIC_CONVEX_URL=

# Secret usado para firmar la cookie de sesion. Generar con: openssl rand -hex 32
SESSION_SECRET=

# Google Gemini API key para la pagina /app/ingestar (foto + texto -> propuestas)
# Generar en https://aistudio.google.com/apikey (free tier 1500 requests/dia)
GEMINI_API_KEY=
